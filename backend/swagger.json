  "info": {
    "title": "CMMS API",
    "description": "The Computerized Maintenance Management System (CMMS) API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Enter JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 100,
            "description": "The unique ID of the product"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "The name of the product"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "CreateAssetDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 100,
            "description": "The unique ID of the asset"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "The name of the asset"
          },
          "location": {
            "type": "string",
            "maxLength": 100,
            "description": "The location (Product ID) of the asset"
          },
          "department": {
            "type": "string",
            "maxLength": 50,
            "description": "The department of the asset"
          }
        },
        "required": [
          "id",
          "name",
          "location",
          "department"
        ]
      },
      "ChecklistItemDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "requiresPhoto": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      },
      "CreatePmTaskDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "assetId": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "nextDueDate": {
            "type": "string"
          },
          "estimatedHours": {
            "type": "number",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "Pending",
              "In Progress",
              "Pending Approval",
              "Done",
              "Overdue"
            ]
          },
          "checklist": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChecklistItemDto"
            }
          },
          "partsRequired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "partsUsed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recordNotes": {
            "type": "string"
          },
          "assignedTo": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "frequency",
          "assetId",
          "productId",
          "department",
          "nextDueDate",
          "estimatedHours"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "employeeId",
          "password"
        ]
      }
    }
  }
}